generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model documents {
  id         BigInt                 @id @default(autoincrement())
  text       String
  metadata   Json?                  @default("{}")
  embedding  Unsupported("vector")?
  created_at DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at DateTime?              @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_documents_created_at")
  @@index([metadata], map: "idx_documents_metadata", type: Gin)
}

model projects {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  title            String
  tagline          String
  industry         String?
  projectType      String?
  status           String?
  role             String
  engagementModel  String?
  teamSize         Int?
  durationInMonths Int?
  problem          String
  context          String?
  strategy         String
  architecture     String
  execution        String
  challenges       String?
  solution         String
  measurableImpact String
  metrics          Json?
  techStack        String[]
  infrastructure   String[]
  integrations     String[]
  coverImage       String
  galleryImages    String[]
  demoUrl          String?
  repositoryUrl    String?
  seoTitle         String?
  seoDescription   String?
  keywords         String[]
  featured         Boolean  @default(false)
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

model testimonials {
  image       String?
  id          Int     @id @default(autoincrement())
  company     String
  content     String
  designation String
  client_name String
}
